# Required for Cursor CLI
CURSOR_API_KEY=

# Required for GitHub: discovery and PR creation (scope: repo)
# https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional: max repos to process per run after filters (default: 5)
FIXER_REPO_LIMIT=5

# Optional: stop after first successful PR (default: 1)
# FIXER_ONE_PR_PER_RUN=1

# Discovery: young repos + stars (defaults: 30 days, 50 stars)
# FIXER_MIN_STARS=50
# FIXER_MAX_REPO_AGE_DAYS=30
# Leave FIXER_MAX_REPO_AGE_DAYS empty to disable created: filter

# Optional: search pool size before CONTRIBUTING / contributed filters (default: max(limit*20, 50), cap 100)
# FIXER_DISCOVERY_POOL_SIZE=60

# Require CONTRIBUTING.md (or fallback paths) via API (default: 1)
# FIXER_REQUIRE_CONTRIBUTING=1

# Skip repos you already opened a PR to (default: 1)
# FIXER_SKIP_REPOS_I_CONTRIBUTED_TO=1

# Re-run test_command from .fixer/context.json in Docker after Phase 3 (default: 0)
# FIXER_VERIFY_TESTS=0

# Optional: cursor-agent model (default if unset: composer-2)
# docker run --rm --entrypoint cursor-agent the-fixer-agent:latest --list-models
FIXER_CURSOR_MODEL=composer-2
